{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 23,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "configuration",
            "hidden": true,
            "binaryDir": "${sourceDir}/build",
            "installDir": "${sourceDir}/install",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_STANDARD": "23"
            }
        },
        {
            "name": "warnings",
            "hidden": true,
            "environment": {
                "CCC_WARNING_C_FLAGS": "-Wall -Wextra -Wvla -Wconversion -Wnull-dereference -Wundef -Wstrict-prototypes -Wwrite-strings -Wfloat-equal -Wtype-limits -Wpointer-arith -Wshadow -Winit-self -Wno-variadic-macros -Wno-gnu-alignof-expression -fno-common"
            }
        },
        {
            "name": "sanitizers",
            "hidden": true,
            "environment": {
                "CCC_SANITIZER_C_FLAGS": "-fanalyzer -fno-omit-frame-pointer -fsanitize-address-use-after-scope -fsanitize=address,leak,undefined,shift,shift-exponent,integer-divide-by-zero,unreachable,null,return,signed-integer-overflow,bounds,bounds-strict,alignment,object-size,float-divide-by-zero,float-cast-overflow,enum,pointer-overflow,pointer-compare,pointer-subtract",
                "CCC_SANITIZER_LINKER_FLAGS": "-fsanitize=address,leak,undefined,shift,shift-exponent,integer-divide-by-zero,unreachable,null,return,signed-integer-overflow,bounds,bounds-strict,alignment,object-size,float-divide-by-zero,float-cast-overflow,enum,pointer-overflow,pointer-compare,pointer-subtract"
            }
        },
        {
            "name": "memory-sanitizers",
            "hidden": true,
            "environment": {
                "CCC_MEMORY_SANITIZER_C_FLAGS": "-fno-omit-frame-pointer -fsanitize=memory -fsanitize-memory-track-origins=2",
                "CCC_MEMORY_SANITIZER_LINKER_FLAGS": "-fsanitize=memory"
            }
        },
        {
            "name": "default-debug",
            "hidden": true,
            "inherits": ["configuration", "warnings"],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/debug/bin",
                "CMAKE_C_FLAGS": "-g3 $env{CCC_WARNING_C_FLAGS}"
            }
        },
        {
            "name": "default-release",
            "hidden": true,
            "inherits": ["configuration", "warnings"],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/build/bin",
                "CMAKE_C_FLAGS": "$env{CCC_WARNING_C_FLAGS}"
            }
        },
        {
            "name": "gcc-debug",
            "inherits": "default-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_C_FLAGS": "-g3 -Og $env{CCC_WARNING_C_FLAGS}"
            }
        },
        {
            "name": "gcc-release",
            "inherits": "default-release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc"
            }
        },
        {
            "name": "clang-debug",
            "inherits": "default-debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang"
            }
        },
        {
            "name": "clang-release",
            "inherits": "default-release",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang"
            }
        },
        {
            "name": "gcc-sanitize-debug",
            "inherits": ["default-debug", "sanitizers"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_C_FLAGS": "-g3 -Og $env{CCC_WARNING_C_FLAGS} $env{CCC_SANITIZER_C_FLAGS}",
                "CMAKE_EXE_LINKER_FLAGS": "$env{CCC_SANITIZER_LINKER_FLAGS}"
            }
        },
        {
            "name": "gcc-sanitize-release",
            "inherits": ["default-release", "sanitizers"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_C_FLAGS": "-g3 $env{CCC_WARNING_C_FLAGS} $env{CCC_SANITIZER_C_FLAGS}",
                "CMAKE_EXE_LINKER_FLAGS": "$env{CCC_SANITIZER_LINKER_FLAGS}"
            }
        },
        {
            "name": "clang-memory-sanitize-debug",
            "inherits": ["default-debug", "memory-sanitizers"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_C_FLAGS": "-g3 -O1 $env{CCC_WARNING_C_FLAGS} $env{CCC_MEMORY_SANITIZER_C_FLAGS}",
                "CMAKE_EXE_LINKER_FLAGS": "$env{CCC_MEMORY_SANITIZER_LINKER_FLAGS}"
            }
        },
        {
            "name": "clang-memory-sanitize-release",
            "inherits": ["default-release", "memory-sanitizers"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_C_FLAGS": "-g3 $env{CCC_WARNING_C_FLAGS} $env{CCC_MEMORY_SANITIZER_C_FLAGS}",
                "CMAKE_EXE_LINKER_FLAGS": "$env{CCC_MEMORY_SANITIZER_LINKER_FLAGS}"
            }
        },
        {
            "name": "gcc-gcov",
            "inherits": ["default-debug"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_C_FLAGS": "--coverage -g3 -Og $env{CCC_WARNING_C_FLAGS}",
                "CMAKE_EXE_LINKER_FLAGS": "--coverage",
                "CCC_ENABLE_COVERAGE": "ON",
                "CCC_COVERAGE_TOOL": "gcov"
            }
        },
        {
            "name": "llvm-cov",
            "inherits": ["default-debug"],
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_C_FLAGS": "--coverage -g3 -Og $env{CCC_WARNING_C_FLAGS}",
                "CMAKE_EXE_LINKER_FLAGS": "--coverage",
                "CCC_ENABLE_COVERAGE": "ON"
            }
        }
    ]
}
